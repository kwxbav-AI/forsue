# === 團隊開發（建議）===
# 向管理員從 1Password 等取得「開發用」Neon 連線，貼在下方。勿 commit 本檔案。
# 設定說明：docs/團隊共用開發資料庫.md
# DATABASE_URL="postgresql://user:pass@ep-xxxx.neon.tech/neondb?sslmode=require"

# === 本機 PostgreSQL（僅個人實驗；通常無上傳資料）===
DATABASE_URL="postgresql://user:password@localhost:5432/daily_performance?schema=public"

# 網頁登入（選填）：設定 AUTH_SECRET（至少 16 字元）後需登入；帳號存在資料庫 AppUser 表
# openssl rand -base64 32
# AUTH_SECRET="your-random-secret-at-least-16-chars"

# 首次 seed 若尚無任何登入帳號，會建立管理員（僅在 appUser 筆數為 0 時）
# SEED_ADMIN_USERNAME="admin"
# SEED_ADMIN_PASSWORD="ChangeMe123!"
