DATABASE_URL="postgresql://user:password@localhost:5432/daily_performance?schema=public"

# 網頁登入（選填）：設定 AUTH_SECRET（至少 16 字元）後需登入；帳號存在資料庫 AppUser 表
# openssl rand -base64 32
# AUTH_SECRET="your-random-secret-at-least-16-chars"

# 首次 seed 若尚無任何登入帳號，會建立管理員（僅在 appUser 筆數為 0 時）
# SEED_ADMIN_USERNAME="admin"
# SEED_ADMIN_PASSWORD="ChangeMe123!"
