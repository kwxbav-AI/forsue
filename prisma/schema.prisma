generator client {
  provider      = "prisma-client-js"
  // native: 本機 Windows/mac
  // debian-openssl-3.0.x: 與本專案 Dockerfile 的 node:20-bookworm-slim（Debian 12 + OpenSSL 3）一致
  // rhel-openssl-3.0.x: 常見其他雲端建置執行環境（如 Vercel 等）使用
  // 若建置/執行改用較舊 Debian（OpenSSL 1.1）或偵測為 debian-openssl-1.1.x，再補上 "debian-openssl-1.1.x"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id               String             @id @default(cuid())
  code             String?            @unique
  name             String             @unique
  department       String?
  isActive         Boolean            @default(true)
  hideInReports    Boolean            @default(false) // 報表/績效頁隱藏（不影響門市啟用/資料對應）
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  employees        Employee[]
  revenues         RevenueRecord[]
  performanceDailies PerformanceDaily[]
  aliases              StoreAlias[]
  storeHourDeductions  StoreHourDeduction[]
  changeLogs           StoreChangeLog[]
  shiftPlans           StoreShiftPlan[]
}

model StoreChangeLog {
  id        String   @id @default(cuid())
  storeId   String
  action    String
  changedBy String?
  before    Json
  after     Json
  changedAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  @@index([storeId, changedAt])
  @@index([changedAt])
}

enum StoreDeductionReason {
  EXPIRY                // 效期
  CLEANING              // 清掃
  INVENTORY_REGISTRATION // 現貨文登記
  OTHER                 // 其他
}

model StoreHourDeduction {
  id        String               @id @default(cuid())
  workDate  DateTime             @db.Date
  storeId   String
  reason    StoreDeductionReason
  hours     Decimal               @db.Decimal(10, 2)
  note      String?
  createdBy String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  store     Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  @@index([workDate])
  @@index([storeId, workDate])
}

model StoreAlias {
  id        String   @id @default(cuid())
  storeId   String
  code      String   @unique
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  @@index([storeId])
}

model Employee {
  id               String               @id @default(cuid())
  employeeCode     String               @unique
  name             String
  defaultStoreId   String?
  position         String?
  hireDate         DateTime?            // 到職日（新進員工工時折算用）
  isReserveStaff   Boolean              @default(false)
  reserveWorkPercent Decimal?           @db.Decimal(5, 2) // 0~100，僅儲備人力使用
  isActive         Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  defaultStore     Store?               @relation(fields: [defaultStoreId], references: [id])
  attendances      AttendanceRecord[]
  dispatches       DispatchRecord[]
  adjustments      WorkhourAdjustment[]
  reserveStaffPeriods EmployeeReserveStaffPeriod[]
}

model EmployeeReserveStaffPeriod {
  id                 String    @id @default(cuid())
  employeeId         String
  effectiveFrom      DateTime  @db.Date
  effectiveTo        DateTime? @db.Date
  isReserveStaff     Boolean
  reserveWorkPercent Decimal?  @db.Decimal(5, 2)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  employee           Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, effectiveFrom])
  @@index([employeeId, effectiveFrom, effectiveTo])
}

model Role {
  id        String   @id @default(cuid())
  key       String   @unique // 例如：ADMIN、EDITOR、VIEWER、STORE_STAFF、或自訂 key
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       AppUser[]
  permissions RolePermission[]
}

enum UploadFileType {
  ATTENDANCE
  DISPATCH
  INVENTORY_REFERENCE
  EMPLOYEE_MASTER
  DAILY_REVENUE
  SHIFT_ROSTER
}

enum ShiftPlanKind {
  WORK
  OFF
  HOLIDAY
  LEAVE
  UNKNOWN
}

enum UploadStatus {
  SUCCESS
  FAILED
}

enum AttendanceLocationMatchStatus {
  MATCH              // 上下班皆符合（或無調度且與部門一致）
  MISMATCH_CLOCKIN   // 上班不符
  MISMATCH_CLOCKOUT  // 下班不符
  MISMATCH_BOTH      // 上下班皆不符
  DISPATCH_EXPLAINED // 可由調度解釋
  NEED_REVIEW        // 有調度時段，但僅上下班打卡不足以驗證中段
  EXCLUDED           // 部門在排除比對清單，且當天無調度
  UNKNOWN            // 無法解析（上/下班資訊空白或格式無法解析）
}

model UploadBatch {
  id            String         @id @default(cuid())
  fileType      UploadFileType
  originalName  String
  storedName    String
  uploadedAt    DateTime       @default(now())
  uploadedBy    String?
  recordCount   Int            @default(0)
  status        UploadStatus   @default(SUCCESS)
  errorMessage  String?
  effectiveDate DateTime?
  versionLabel  String?
}

model AttendanceRecord {
  id              String     @id @default(cuid())
  workDate        DateTime   @db.Date
  employeeId      String
  originalStoreId String?
  department      String?
  workHours       Decimal    @db.Decimal(10, 2)
  scheduledWorkHours Decimal? @db.Decimal(10, 2) // 表定工時（用於判斷請假/未到齊）
  startTime       String?
  endTime         String?
  clockInInfoRaw   String?
  clockOutInfoRaw  String?
  clockInStoreText String?
  clockOutStoreText String?
  clockInStoreId   String?
  clockOutStoreId  String?
  locationMatchStatus AttendanceLocationMatchStatus @default(UNKNOWN)
  shiftType       String?
  uploadBatchId   String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  employee        Employee   @relation(fields: [employeeId], references: [id])
  @@index([workDate])
  @@index([employeeId, workDate])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model StoreShiftPlan {
  id              String        @id @default(cuid())
  workDate        DateTime      @db.Date
  storeId         String
  employeeCode    String
  employeeName    String?
  employeeId      String?
  shiftKind       ShiftPlanKind @default(WORK)
  startTime       String?
  endTime         String?
  scheduledHours  Decimal       @db.Decimal(10, 2)
  rawCell         String?
  uploadBatchId   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, workDate, employeeCode])
  @@index([workDate])
  @@index([storeId, workDate])
}

model DispatchRecord {
  id              String     @id @default(cuid())
  workDate        DateTime   @db.Date
  employeeId      String
  fromStoreId     String?
  toStoreId       String
  dispatchHours   Decimal    @db.Decimal(10, 2)  // 預申請時數
  actualHours     Decimal?   @db.Decimal(10, 2) // 實際時數（事後確認填寫，績效計算優先使用）
  confirmStatus   String?   // 待確認 | 已確認
  startTime       String?
  endTime         String?
  remark          String?
  uploadBatchId   String?
  createdBy       String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  employee        Employee   @relation(fields: [employeeId], references: [id])
  @@index([workDate])
  @@index([employeeId, workDate])
}

model RevenueRecord {
  id            String   @id @default(cuid())
  revenueDate   DateTime @db.Date
  storeId       String
  checkoutNo    String?
  revenueAmount Decimal  @db.Decimal(12, 2)
  cashIncome    Decimal  @db.Decimal(12, 2) @default(0)
  linePayAmount Decimal  @db.Decimal(12, 2) @default(0)
  expenseAmount Decimal  @db.Decimal(12, 2) @default(0)
  uploadBatchId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store         Store    @relation(fields: [storeId], references: [id])
  @@index([revenueDate])
  @@index([storeId, revenueDate])
  @@unique([storeId, revenueDate, checkoutNo])
}

enum AdjustmentType {
  STAFF_SHORTAGE    // 人力不足
  MEETING_REVIEW    // 會議/考核
  RESERVE_STAFF     // 儲備人力
  TRIAL             // 試作
  MANAGER_MEETING   // 店長會議
  PROMOTION_REVIEW  // 晉升考核
  OTHER             // 其他
}

model WorkhourAdjustment {
  id              String         @id @default(cuid())
  workDate        DateTime       @db.Date
  employeeId      String
  storeId         String?
  adjustmentType  AdjustmentType
  adjustmentHours Decimal        @db.Decimal(10, 2)
  reason          String?
  note            String?
  createdBy       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  employee        Employee       @relation(fields: [employeeId], references: [id])
  @@index([workDate])
  @@index([employeeId, workDate])
}

model PerformanceTargetSetting {
  id                  String    @id @default(cuid())
  targetValue         Decimal   @db.Decimal(10, 2)
  effectiveStartDate  DateTime  @db.Date
  effectiveEndDate    DateTime? @db.Date
  isActive            Boolean   @default(true)
  updatedBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  @@index([effectiveStartDate, effectiveEndDate])
}

model PerformanceDaily {
  id              String   @id @default(cuid())
  workDate        DateTime @db.Date
  storeId         String
  revenueAmount   Decimal  @db.Decimal(12, 2)
  totalWorkHours  Decimal  @db.Decimal(10, 2)
  efficiencyRatio Decimal  @db.Decimal(12, 2)
  targetValue     Decimal  @db.Decimal(10, 2)
  isTargetMet     Boolean
  calculatedAt    DateTime @default(now())
  versionNo       Int      @default(1)
  store           Store    @relation(fields: [storeId], references: [id])
  @@unique([workDate, storeId, versionNo])
  @@index([workDate])
  @@index([storeId, workDate])
}

model AuditLog {
  id         String   @id @default(cuid())
  module     String
  action     String
  targetType String
  targetId   String?
  beforeJson Json?
  afterJson  Json?
  operator   String?
  createdAt  DateTime @default(now())
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date])
}

model ContentEntry {
  id              String   @id @default(cuid())
  workDate        DateTime @db.Date
  branch          String
  totalArticles   Int?
  contentDesc1    String?
  articleUrl1     String?
  productCount1   Int?
  commentCount1   Int?
  contentDesc2    String?
  articleUrl2     String?
  productCount2   Int?
  commentCount2   Int?
  contentDesc3    String?
  articleUrl3     String?
  productCount3   Int?
  commentCount3   Int?
  deductedMinutes Int?     // 扣工時（分鐘），依規則計算後儲存
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([workDate])
  @@index([workDate, branch])
}

/// 網頁登入帳號（與 Employee 無關）
enum UserRole {
  ADMIN // 全部功能 + 帳號管理
  EDITOR // 營運填報、上傳、設定（不含帳號管理）
  VIEWER // 僅報表與工效查詢（唯讀）
  STORE_STAFF // 門市人員（依可設定權限）
}

model AppUser {
  id            String   @id @default(cuid())
  username      String   @unique
  passwordHash  String
  legacyRole    UserRole @default(EDITOR) @map("role")
  roleId        String?
  role          Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  retailStoreId String?  @map("retail_store_id")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  retailStore      RetailStore?      @relation(fields: [retailStoreId], references: [id], onDelete: SetNull)
  supervisorStores SupervisorStore[]

  @@index([roleId])
  @@index([retailStoreId])
}

enum PermissionPatternKind {
  PAGE // 網頁路徑（pathname）
  API // API 路徑（pathname + method）
}

model PermissionModule {
  id          String    @id @default(cuid())
  key         String    @unique // 例如：workhour-related、dispatches、content-entries
  label       String
  description String?
  groupKey    String    @default("") // UI 分組用（例如：工時異動相關、報表、設定）
  sortOrder   Int       @default(0)
  parentId    String?   // 同頁子功能縮排（例如 uploads-* 掛在 uploads 底下）
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parent      PermissionModule? @relation("PermissionModuleParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    PermissionModule[] @relation("PermissionModuleParent")
  patterns PermissionModuleApiPattern[]
  rolePermissions RolePermission[]

  @@index([groupKey, sortOrder])
  @@index([parentId])
}

model PermissionModuleApiPattern {
  id          String               @id @default(cuid())
  moduleId    String
  kind        PermissionPatternKind
  pathPattern String              // 用來做 pathname 的 startsWith 比對（例如：/dispatches 或 /api/dispatches）
  method      String?             // 可選：限制 HTTP method（例如：GET/POST）；未填代表任何 method

  module      PermissionModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId, kind])
  @@unique([moduleId, kind, pathPattern, method])
}

model RolePermission {
  id         String    @id @default(cuid())
  legacyRole UserRole  @map("role")
  roleId     String?
  moduleId   String
  canRead    Boolean   @default(false)
  canWrite   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  role       Role?     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module     PermissionModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId], map: "RolePermission_roleId_moduleId_key")
  @@index([legacyRole], map: "RolePermission_role_idx")
  @@index([roleId])
}

enum DeletionRequestTargetType {
  CONTENT_ENTRY
  WORKHOUR_ADJUSTMENT
  STORE
  STORE_HOUR_DEDUCTION
  DISPATCH_RECORD
  REVENUE_RECORD
}

enum DeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model DeletionRequest {
  id                  String                   @id @default(cuid())
  targetType          DeletionRequestTargetType
  targetId            String
  targetSummary       String?
  status              DeletionRequestStatus    @default(PENDING)
  reason              String?
  requestedByUserId   String?
  requestedByUsername String?
  reviewedByUsername  String?
  reviewedAt          DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([status, createdAt])
  @@index([targetType, targetId])
}

// --- 零售門市營運分析（營運總覽 Dashboard）---

model RetailStore {
  id                     String   @id @default(cuid())
  storeName              String   @map("store_name")
  region                 String?
  managerName             String?  @map("manager_name")
  dailyBusinessHours      Decimal? @map("daily_business_hours") @db.Decimal(10, 2)
  weekdayBusinessHours    Decimal? @map("weekday_business_hours") @db.Decimal(10, 2)
  saturdayBusinessHours   Decimal? @map("saturday_business_hours") @db.Decimal(10, 2)
  defaultLaborHoursPerDay Decimal? @map("default_labor_hours_per_day") @db.Decimal(10, 2)
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  storeTargets          StoreTarget[]
  dailyPerformances     DailyStorePerformance[]
  tmsTransactions       TmsTransaction[]
  staffSchedules        StaffSchedule[]
  dailyReports          DailyReport[]
  todoItems             TodoItem[]
  repairRequests        RepairRequest[]
  supplyRequests        SupplyRequest[]
  wishItems             WishItem[]
  supervisorStores      SupervisorStore[]
  appUsers              AppUser[]

  @@unique([storeName])
  @@map("stores")
}

model StoreTarget {
  id               String   @id @default(cuid())
  storeId          String   @map("store_id")
  year             Int
  month            Int
  salesTarget      Decimal  @map("sales_target") @db.Decimal(14, 2)
  laborHourTarget  Decimal  @map("labor_hour_target") @db.Decimal(10, 2)
  rplhTarget       Decimal? @map("rplh_target") @db.Decimal(12, 4)
  note             String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  store RetailStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, year, month])
  @@index([year, month])
  @@map("store_targets")
}

model DailyStorePerformance {
  id              String   @id @default(cuid())
  storeId         String   @map("store_id")
  date            DateTime @db.Date
  salesAmount     Decimal  @default(0) @map("sales_amount") @db.Decimal(14, 2)
  customerCount   Int      @default(0) @map("customer_count")
  avgOrderValue   Decimal? @map("avg_order_value") @db.Decimal(12, 2)
  totalLaborHours Decimal  @default(0) @map("total_labor_hours") @db.Decimal(10, 2)
  overtimeHours   Decimal  @default(0) @map("overtime_hours") @db.Decimal(10, 2)
  leaveHours      Decimal  @default(0) @map("leave_hours") @db.Decimal(10, 2)
  weather         String?
  eventNote       String?  @map("event_note")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  store RetailStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@index([date])
  @@map("daily_store_performance")
}

model TmsTransaction {
  id              String   @id @default(cuid())
  storeId         String   @map("store_id")
  transactionTime DateTime @map("transaction_time")
  orderNo         String   @map("order_no")
  amount          Decimal  @db.Decimal(14, 2)
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  store RetailStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, transactionTime])
  @@map("tms_transactions")
}

model StaffSchedule {
  id         String   @id @default(cuid())
  storeId    String   @map("store_id")
  staffName  String   @map("staff_name")
  workDate   DateTime @map("work_date") @db.Date
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  position   String?
  isManager  Boolean  @default(false) @map("is_manager")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  store RetailStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, workDate])
  @@map("staff_schedules")
}

// --- 店務回報平台整合（工作日誌、任務、報修、公佈欄、物資、許願池）---

enum DailyReportStatus {
  DRAFT
  SUBMITTED
}

model DailyReport {
  id          String            @id @default(cuid())
  storeId     String            @map("store_id")
  reportDate  DateTime          @db.Date @map("report_date")
  mainWork    String?           @map("main_work")
  anomaly     String?
  submittedAt DateTime?         @map("submitted_at")
  submittedBy String?           @map("submitted_by")
  status      DailyReportStatus @default(DRAFT)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  store       RetailStore       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, reportDate])
  @@index([reportDate])
  @@index([storeId, reportDate])
  @@map("daily_reports")
}

enum TodoStatus {
  PENDING
  IN_PROGRESS
  DONE
  OVERDUE
}

model TodoItem {
  id          String     @id @default(cuid())
  storeId     String     @map("store_id")
  title       String
  description String?
  dueDate     DateTime?  @db.Date @map("due_date")
  status      TodoStatus @default(PENDING)
  createdBy   String?    @map("created_by")
  completedAt DateTime?  @map("completed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  store       RetailStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, dueDate])
  @@map("todo_items")
}

enum RepairStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

model RepairRequest {
  id          String       @id @default(cuid())
  storeId     String       @map("store_id")
  equipment   String
  description String?
  status      RepairStatus @default(PENDING)
  resolvedAt  DateTime?    @map("resolved_at")
  resolvedBy  String?      @map("resolved_by")
  createdBy   String?      @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  store       RetailStore  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([createdAt])
  @@map("repair_requests")
}

enum AnnouncementTarget {
  ALL
  REGION
  STORE
}

model Announcement {
  id            String             @id @default(cuid())
  title         String
  content       String
  targetType    AnnouncementTarget @default(ALL)
  targetRegion  String?            @map("target_region")
  targetStoreId String?            @map("target_store_id")
  publishedBy   String?            @map("published_by")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("announcements")
}

enum SupplyStatus {
  PENDING
  APPROVED
  REJECTED
  SHIPPED
  RECEIVED
}

model SupplyRequest {
  id           String       @id @default(cuid())
  storeId      String       @map("store_id")
  itemName     String       @map("item_name")
  quantity     String?
  neededDate   DateTime?    @db.Date @map("needed_date")
  note         String?
  status       SupplyStatus @default(PENDING)
  submittedBy  String?      @map("submitted_by")
  submittedAt  DateTime     @default(now()) @map("submitted_at")
  reviewedBy   String?      @map("reviewed_by")
  reviewedAt   DateTime?    @map("reviewed_at")
  rejectReason String?      @map("reject_reason")
  shippedBy    String?      @map("shipped_by")
  shippedAt    DateTime?    @map("shipped_at")
  receivedBy   String?      @map("received_by")
  receivedAt   DateTime?    @map("received_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  store        RetailStore  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([status])
  @@map("supply_requests")
}

model WishItem {
  id            String    @id @default(cuid())
  storeId       String    @map("store_id")
  title         String
  description   String?
  endorseCount  Int       @default(0) @map("endorse_count")
  purchaseReply String?   @map("purchase_reply")
  repliedBy     String?   @map("replied_by")
  repliedAt     DateTime? @map("replied_at")
  createdBy     String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  store         RetailStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("wish_items")
}

model SupervisorStore {
  id           String      @id @default(cuid())
  supervisorId String      @map("supervisor_id")
  storeId      String      @map("store_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  supervisor   AppUser     @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
  store        RetailStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([supervisorId, storeId])
  @@index([supervisorId])
  @@map("supervisor_stores")
}
